# ==============================================================================
# SYSTEM INTERFACE LOGIC & MAIN LAYOUT GENERATORS
# ==============================================================================
def get_main_keyboard(lang):
    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
    if lang == 'BN':
        markup.row('📋 Tasks / কাজ', '💰 Balance / ব্যালেন্স', '💳 Withdraw / উইথড্র')
        markup.row('📊 My Report / রিপোর্ট', '🔗 Invite Link / রেফার', '🧾 Proof List / প্রুফ লিস্ট')
        markup.row('📖 How to Work / ভিডিও গাইড', '📞 Helpline / সাপোর্ট')
    else:
        markup.row('📋 Tasks / काम', '💰 Balance', '💳 Withdraw')
        markup.row('📊 My Report', '🔗 Invite Link', '🧾 Proof List')
        markup.row('📖 How to Work', '📞 Helpline')
    return markup

def get_cancel_keyboard(lang):
    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
    markup.add('❌ বাতিল করুন / Cancel')
    return markup

# ==============================================================================
# TELEGRAM INCOMING COMMAND ENGINE ROUTER
# ==============================================================================
@bot.message_with_type_handler(commands=['start'], content_types=['text'])
def send_welcome(message):
    user_id = message.from_user.id
    first_name = message.from_user.first_name
    
    # Handle deep-linking referral structure logic
    args = message.text.split()
    referrer = 0
    if len(args) > 1 and args[1].isdigit():
        referrer = int(args[1])
        if referrer == user_id:
            referrer = 0

    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT lang FROM users WHERE user_id=?", (user_id,))
    row = cursor.fetchone()
    
    if not row:
        cursor.execute("INSERT INTO users (user_id, first_name, referred_by) VALUES (?, ?, ?)", (user_id, first_name, referrer))
        conn.commit()
        
        # Display language gate selection buttons on fresh entry
        markup = types.InlineKeyboardMarkup()
        markup.row(
            types.InlineKeyboardButton("🇧🇩 বাংলা", callback_data="setlang_BN"),
            types.InlineKeyboardButton("🇺🇸 English", callback_data="setlang_EN")
        )
        bot.send_message(user_id, "🎯 Please select your preferred language / ভাষা নির্বাচন করুন:", reply_markup=markup)
    else:
        lang = row[0]
        bot.send_message(user_id, msg('welcome', lang), reply_markup=get_main_keyboard(lang))
    conn.close()

# ==============================================================================
# BUTTON CLICKS INTERACTION ROUTERS & HANDLERS
# ==============================================================================
@bot.message_handler(func=lambda message: True)
def handle_menu_navigation(message):
    user_id = message.from_user.id
    text = message.text
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT lang, balance FROM users WHERE user_id=?", (user_id,))
    user_row = cursor.fetchone()
    
    if not user_row:
        conn.close()
        return
    
    lang, balance = user_row
    
    # Global Escape Management
    if text == '❌ বাতিল করুন / Cancel' or text == '🔙 প্রধান মেনু / Main Menu':
        user_states.pop(user_id, None)
        bot.send_message(user_id, msg('main_menu', lang), reply_markup=get_main_keyboard(lang))
        conn.close()
        return

    # Process Active Step Chains First
    if user_id in user_states:
        state_data = user_states[user_id]
        state_type = state_data.get('type')
        
        if state_type == 'withdraw':
            try:
                parts = text.split(maxsplit=1)
                address = parts[0]
                amount = float(parts[1])
                
                if amount > balance or amount <= 0:
                    bot.send_message(user_id, msg('with_err', lang))
                    conn.close()
                    return
                
                cursor.execute("UPDATE users SET balance = balance - ? WHERE user_id=?", (amount, user_id))
                cursor.execute("INSERT INTO withdraws (user_id, method, amount, address, timestamp) VALUES (?, ?, ?, ?, ?)",
                               (user_id, state_data['method'], amount, address, int(time.time())))
                conn.commit()
                user_states.pop(user_id, None)
                bot.send_message(user_id, msg('with_success', lang), reply_markup=get_main_keyboard(lang))
            except Exception:
                bot.send_message(user_id, "❌ Syntax Error! Format: [Address] [Amount]")
            conn.close()
            return
            
        elif state_type == 'task_input':
            # Complete task data processing flow
            parts = [p.strip() for p in text.split(',')]
            platform = state_data['platform']
            
            # Anti-Spam Gate checking
            if is_spammer(user_id):
                bot.send_message(user_id, msg('spam_lock', lang), reply_markup=get_main_keyboard(lang))
                user_states.pop(user_id, None)
                conn.close()
                return
                
            # Anti-Fraud Verification Verification Gates
            if platform == 'YouTube':
                if len(parts) < 1 or state_data['verification_string'].lower() not in parts[0].lower():
                    bot.send_message(user_id, msg('proof_err', lang))
                    cursor.execute("INSERT INTO submissions (user_id, task_main, task_sub, username, password, recovery, status, timestamp) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                                   (user_id, platform, 'Channel', parts[0] if len(parts)>0 else 'N/A', 'N/A', 'N/A', 'Rejected', int(time.time())))
                    conn.commit()
                    conn.close()
                    return
                username, password, recovery, tfa, cookies = parts[0], "N/A", "N/A", "N/A", "N/A"
            else:
                if len(parts) < 3 or state_data['verification_string'].lower() not in parts[0].lower():
                    bot.send_message(user_id, msg('proof_err', lang))
                    cursor.execute("INSERT INTO submissions (user_id, task_main, task_sub, username, password, recovery, status, timestamp) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
                                   (user_id, platform, 'Account', parts[0] if len(parts)>0 else 'N/A', 'N/A', 'N/A', 'Rejected', int(time.time())))
                    conn.commit()
                    conn.close()
                    return
                
                username = parts[0]
                password = parts[1]
                recovery = parts[2]
                tfa = parts[3] if len(parts) > 3 else "N/A"
                cookies = parts[4] if len(parts) > 4 else "N/A"
                
                # Check 2FA Locks Requirement conditions dynamically
                if platform in ['Instagram', 'FB_Hotmail', 'FB_Cookies', 'Twitter', 'TikTok'] and (tfa == "N/A" or len(tfa) < 4):
                    bot.send_message(user_id, "❌ Error: 2FA Secret Key string is mandatory for this social platform assignment!")
                    conn.close()
                    return

            cursor.execute("""
                INSERT INTO submissions (user_id, task_main, task_sub, username, password, recovery, tfa_key, cookies, status, timestamp)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'Pending', ?)
            """, (user_id, platform, 'Verification Lock Passed', username, password, recovery, tfa, cookies, int(time.time())))
            conn.commit()
            user_states.pop(user_id, None)
            bot.send_message(user_id, msg('sub_success', lang), reply_markup=get_main_keyboard(lang))
            conn.close()
            return

    # Handle Primary Interfaces Choices Routing
    if text in ['📋 Tasks / কাজ', '📋 Tasks / काम']:
        cursor.execute("SELECT platform, price, logo FROM rates")
        rows = cursor.fetchall()
        markup = types.InlineKeyboardMarkup(row_width=1)
        for name, price, logo in rows:
            display_text = f"{logo} {name} - ৳ {price:.2f} BDT"
            markup.add(types.InlineKeyboardButton(display_text, callback_data=f"play_{name}"))
        bot.send_message(user_id, msg('task_list', lang), reply_markup=markup)
        
    elif text in ['💰 Balance / ব্যালেন্স', '💰 Balance']:
        usd_r = float(get_setting('usd_rate'))
        usd_balance = balance / usd_r
        bot.send_message(user_id, msg('balance', lang).format(balance, usd_balance))
        
    elif text in ['💳 Withdraw / উইথড্র', '💳 Withdraw']:
        markup = types.InlineKeyboardMarkup()
        markup.row(
            types.InlineKeyboardButton("📱 Recharge", callback_data="w_Recharge"),
            types.InlineKeyboardButton("Bkash / Nagad", callback_data="w_MobileBanking")
        )
        markup.row(types.InlineKeyboardButton("Binance (USD)", callback_data="w_Binance"))
        bot.send_message(user_id, msg('with_select', lang), reply_markup=markup)
        
    elif text in ['🔗 Invite Link / রেফার', '🔗 Invite Link']:
        bot_info = bot.get_me()
        comm = get_setting('ref_commission')
        
        # Real-time referral mapping extraction pulling actual Telegram First Names
        cursor.execute("SELECT first_name FROM users WHERE referred_by=?", (user_id,))
        refs = cursor.fetchall()
        ref_list_str = "\n".join([f"🔹 {r[0]}" for r in refs]) if refs else "🚫 No workers referred yet."
        
        bot.send_message(user_id, msg('invite', lang).format(comm, bot_info.username, user_id, ref_list_str))
        
    elif text in ['📊 My Report / রিপোর্ট', '📊 My Report', '🧾 Proof List / প্রুফ লিস্ট', '🧾 Proof List']:
        cursor.execute("SELECT task_main, status, timestamp FROM submissions WHERE user_id=? ORDER BY sub_id DESC LIMIT 10", (user_id,))
        rows = cursor.fetchall()
        report = "📊 **Your Recent Task Log:**\n\n" if lang == 'EN' else "📊 **আপনার সাম্প্রতিক কাজের খতিয়ান:**\n\n"
        if not rows:
            report += "🚫 No tasks submitted yet."
        for p, stat, ts in rows:
            report += f"🔹 {p} - `{stat}` ({time.strftime('%d/%m %I:%M %p', time.localtime(ts))})\n"
        bot.send_message(user_id, report, parse_mode="Markdown")
        
    elif text in ['📖 How to Work / ভিডিও গাইড', '📖 How to Work']:
        url = get_setting('tutorial_video')
        bot.send_message(user_id, f"📖 Watch our system training guidelines:\n🔗 {url}")
        
    elif text in ['📞 Helpline / সাপোর্ট', '📞 Helpline']:
        cursor.execute("SELECT channel_name, url FROM support_links")
        links = cursor.fetchall()
        markup = types.InlineKeyboardMarkup(row_width=1)
        for name, url in links:
            markup.add(types.InlineKeyboardButton(text=name, url=url))
        bot.send_message(user_id, "📞 Click below to access dynamic live help queues:", reply_markup=markup)

    conn.close()

# ==============================================================================
# INLINE CALLBACK OPERATIONS PROCESSING LOGIC
# ==============================================================================
@bot.callback_query_handler(func=lambda call: True)
def handle_callbacks(call):
    user_id = call.from_user.id
    data = call.data
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    if data.startswith("setlang_"):
        selected_lang = data.split("_")[1]
        cursor.execute("UPDATE users SET lang=? WHERE user_id=?", (selected_lang, user_id))
        conn.commit()
        bot.delete_message(user_id, call.message.message_id)
        bot.send_message(user_id, msg('welcome', selected_lang), reply_markup=get_main_keyboard(selected_lang))
        
    elif data.startswith("w_"):
        method = data.split("_")[1]
        cursor.execute("SELECT lang FROM users WHERE user_id=?", (user_id,))
        lang = cursor.fetchone()[0]
        user_states[user_id] = {'type': 'withdraw', 'method': method}
        bot.send_message(user_id, msg('with_input', lang), reply_markup=get_cancel_keyboard(lang))
        
    elif data.startswith("play_"):
        platform = data.split("_")[1]
        cursor.execute("SELECT lang FROM users WHERE user_id=?", (user_id,))
        lang = cursor.fetchone()[0]
        
        # Generation Logic for simulated microtask identities
        random_str = ''.join(random.choices(string.ascii_lowercase + string.digits, k=6))
        generated_email = f"worker.{random_str}@microearn.com"
        generated_handle = f"@user_{random_str}"
        generated_pass = ''.join(random.choices(string.ascii_letters + string.digits, k=10))
        
        if platform == 'YouTube':
            inst = f"🎬 **YouTube Target Assignment:**\n\n" \
                   f"1. Open YouTube app.\n" \
                   f"2. Create a channel matching handle precisely: `{generated_handle}`\n" \
                   f"3. Hit completion button below and submit channel handle text."
            verification = generated_handle
        else:
            inst = f"📧 **Credential Creation Protocol for {platform}:**\n\n" \
                   f"📋 Recommended Email Asset: `{generated_email}`\n" \
                   f"🔐 Target System Password: `{generated_pass}`\n" \
                   f"🎒 Alternative Recovery Node: `backup@microearn.com`\n\n" \
                   f"⚠️ **Submission Rule Format:**\n" \
                   f"You must paste values separated by commas exactly like:\n" \
                   f"`[Email/Username], [Password], [Recovery Mail], [2FA Key], [Cookies]`\n\n" \
                   f"👉 Note: The username string MUST strictly contain: `{random_str}`"
            verification = random_str
            
        user_states[user_id] = {
            'type': 'task_input',
            'platform': platform,
            'verification_string': verification
        }
        bot.send_message(user_id, inst, parse_mode="Markdown", reply_markup=get_cancel_keyboard(lang))
        
    elif data.startswith("rev_") or data.startswith("rej_"):
        # Admin Review Processing Logic Engine
        # Verify access permission rights against admin tables matching sender context
        cursor.execute("SELECT role FROM admins WHERE admin_id=?", (user_id,))
        role_row = cursor.fetchone()
        if not role_row:
            bot.answer_callback_query(call.id, "❌ Access Control Violation!")
            conn.close()
            return
            
        action, sub_id = data.split("_")[1], int(data.split("_")[2])
        cursor.execute("SELECT user_id, task_main, status FROM submissions WHERE sub_id=?", (sub_id,))
        sub_row = cursor.fetchone()
        
        if sub_row and sub_row[2] == 'Pending':
            worker_id, platform, _ = sub_row
            if action == 'app':
                cursor.execute("SELECT price FROM rates WHERE platform=?", (platform,))
                payout = cursor.fetchone()[0]
                
                # Update Worker balance parameter values
                cursor.execute("UPDATE users SET balance = balance + ? WHERE user_id=?", (payout, worker_id))
                cursor.execute("UPDATE submissions SET status='Approved' WHERE sub_id=?", (sub_id,))
                
                # Dynamic Referral Tier Commission Processing Logic splits payouts
                cursor.execute("SELECT referred_by FROM users WHERE user_id=?", (worker_id,))
                ref_id = cursor.fetchone()[0]
                if ref_id > 0:
                    ref_bonus = float(get_setting('ref_commission'))
                    cursor.execute("UPDATE users SET balance = balance + ? WHERE user_id=?", (ref_bonus, ref_id))
                    try: bot.send_message(ref_id, f"🎁 Referral Bonus Credited: ৳{ref_bonus} BDT from Worker #{worker_id}!")
                    except: pass
                    
                bot.send_message(worker_id, f"✅ Task Approved! Payout of ৳{payout} BDT has been credited to your balance.")
                bot.edit_message_text(f"✅ Submission #{sub_id} Approved by Moderator.", call.message.chat.id, call.message.message_id)
            else:
                cursor.execute("UPDATE submissions SET status='Rejected' WHERE sub_id=?", (sub_id,))
                bot.send_message(worker_id, "❌ Your account creation data submission was Rejected by administration auditing.")
                bot.edit_message_text(f"❌ Submission #{sub_id} Rejected by Moderator.", call.message.chat.id, call.message.message_id)
            conn.commit()
        else:
            bot.answer_callback_query(call.id, "❌ Assignment already closed or missing.")
            
    elif data.startswith("pay_"):
        action, w_id = data.split("_")[1], int(data.split("_")[2])
        cursor.execute("SELECT user_id, amount, status FROM withdraws WHERE w_id=?", (w_id,))
        w_row = cursor.fetchone()
        
        if w_row and w_row[2] == 'Pending':
            worker_id, amount, _ = w_row
            if action == 'app':
                cursor.execute("UPDATE withdraws SET status='Paid', txn_id=? WHERE w_id=?", (f"TXN{int(time.time())}", w_id))
                bot.send_message(worker_id, f"🎉 Cashout Success! Your payout request of {amount} has been wired.")
                bot.edit_message_text(f"✅ Cashout #{w_id} updated to PAID.", call.message.chat.id, call.message.message_id)
            else:
                cursor.execute("UPDATE users SET balance = balance + ? WHERE user_id=?", (amount, worker_id))
                cursor.execute("UPDATE withdraws SET status='Rejected' WHERE w_id=?", (w_id,))
                bot.send_message(worker_id, f"❌ Cashout Rejected! {amount} has been reverted to your balance assets.")
                bot.edit_message_text(f"❌ Cashout #{w_id} updated to REJECTED.", call.message.chat.id, call.message.message_id)
            conn.commit()

    conn.close()

