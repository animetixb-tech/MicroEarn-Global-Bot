def add_custom_task_configuration(message):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT role FROM admins WHERE admin_id=?", (message.from_user.id,))
    if not cursor.fetchone(): 
        conn.close()
        return
    try:
        parts = message.text.split(maxsplit=3)
        name, payout, logo = parts[1], float(parts[2]), parts[3]
        cursor.execute("INSERT OR REPLACE INTO rates (platform, price, logo) VALUES (?, ?, ?)", (name, payout, logo))
        conn.commit()
        bot.reply_to(message, f"✅ Dynamic Task Configuration Live! Platform: {logo} {name} at ৳{payout} BDT.")
    except: bot.reply_to(message, "Syntax: `/addtask [Name] [Payout_BDT] [Emoji_Logo]`")
    conn.close()

