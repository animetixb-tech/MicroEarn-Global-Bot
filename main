# Enterprise Grade High Security Two-Sheet Automated Data Export Framework
# HIGHLIGHTED SEGREGATION EXPLANATION:
# - `/workreport`: Generates a completely safe telemetry log. No raw passwords, 
#   no 2FA credentials, no raw account cookies are exported. Completely safe for assistants.
# - `/exportbuyer`: Only executable by Main Owner (7736281687). Compiles raw, premium, 
#   complete accounts data assets with usernames, passwords, 2FA keys, cookies instantly.
# ==============================================================================

@bot.message_with_type_handler(commands=['workreport'], content_types=['text'])
def export_worker_telemetry(message):
    user_id = message.from_user.id
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT role FROM admins WHERE admin_id=?", (user_id,))
    row = cursor.fetchone()
    
    if not row:
        bot.reply_to(message, "❌ Access Control Violation! Unauthorized role permission context.")
        conn.close()
        return
        
    # Compile 24-hour safe telemetry logs
    ts_cutoff = int(time.time()) - 86400
    cursor.execute("""
        SELECT u.user_id, u.first_name, s.task_main,
               COUNT(s.sub_id) as total,
               SUM(CASE WHEN s.status='Approved' THEN 1 ELSE 0 END) as app_cnt,
               SUM(CASE WHEN s.status='Rejected' THEN 1 ELSE 0 END) as rej_cnt
        FROM users u
        JOIN submissions s ON u.user_id = s.user_id
        WHERE s.timestamp >= ?
        GROUP BY u.user_id, s.task_main
    """, (ts_cutoff,))
    rows = cursor.fetchall()
    conn.close()
    
    filename = "assistant_worker_report.csv"
    with open(filename, 'w', newline='', encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerow(['User ID', 'Telegram Name', 'Platform Name', 'Total Submitted', 'Approved Count', 'Rejected Count', 'Success Ratio %'])
        for r in rows:
            ratio = (r[4] / r[3] * 100) if r[3] > 0 else 0.0
            writer.writerow([r[0], r[1], r[2], r[3], r[4], r[5], f"{ratio:.2f}%"])
            
    with open(filename, 'rb') as doc:
        bot.send_document(user_id, doc, caption="📊 Safe Team Worker Telemetry Analytics (Masked Passwords/2FA Keys Asset).")
    os.remove(filename)

@bot.message_with_type_handler(commands=['exportbuyer'], content_types=['text'])
def export_premium_buyer_assets(message):
    user_id = message.from_user.id
    
    # SYSTEM CRITICAL OWNER HARD-LOCK AUDIT CHECK
    if user_id != OWNER_ID:
        bot.reply_to(message, "🚨 CRITICAL VIOLATION WARNING: This configuration payload download gate is locked entirely to the System Root Owner!")
        return
        
    args = message.text.split()
    if len(args) < 2:
        bot.reply_to(message, "✍️ Syntax Layout Parameter Needed: `/exportbuyer [Platform_Name]`\nExample: `/exportbuyer Gmail`")
        return
        
    platform = args[1]
    ts_cutoff = int(time.time()) - 86400
    
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("""
        SELECT task_main, username, password, recovery, tfa_key, cookies, timestamp
        FROM submissions
        WHERE task_main=? AND status='Approved' AND timestamp >= ?
    """, (platform, ts_cutoff))
    rows = cursor.fetchall()
    conn.close()
    
    if not rows:
        bot.reply_to(message, f"❌ No approved batch entries recorded under target platform parameter: {platform} within the trailing 24 hours.")
        return
        
    filename = f"buyer_master_sheet_{platform}.csv"
    with open(filename, 'w', newline='', encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerow(['Platform', 'Username/Email', 'Password', 'Recovery Mail', '2FA Secret Key', 'Cookies String', 'Timestamp Approved'])
        for r in rows:
            writer.writerow([r[0], r[1], r[2], r[3], r[4], r[5], time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(r[6]))])
            
    with open(filename, 'rb') as doc:
        bot.send_document(OWNER_ID, doc, caption=f"🔑 Master Bulk Account Export for Buyer Distribution: **{platform}** (Complete Credentials Unmasked).")
    os.remove(filename)

