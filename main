DB_FILE = "microearn_global.db"

bot = TeleBot(BOT_TOKEN)

# Runtime state storage for multi-step input handling
user_states = {}

# ==============================================================================
# DATABASE ENGINE AND LAYER SEEDING
# ==============================================================================
def init_db():
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            first_name TEXT,
            balance REAL DEFAULT 0.0,
            lang TEXT DEFAULT 'BN',
            referred_by INTEGER DEFAULT 0
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS submissions (
            sub_id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            task_main TEXT,
            task_sub TEXT,
            username TEXT,
            password TEXT,
            recovery TEXT,
            tfa_key TEXT DEFAULT 'N/A',
            cookies TEXT DEFAULT 'N/A',
            status TEXT DEFAULT 'Pending',
            timestamp INTEGER
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS withdraws (
            w_id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            method TEXT,
            amount REAL,
            address TEXT,
            txn_id TEXT DEFAULT 'N/A',
            status TEXT DEFAULT 'Pending',
            timestamp INTEGER
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS rates (
            platform TEXT PRIMARY KEY,
            price REAL,
            logo TEXT,
            custom_fields TEXT DEFAULT 'N/A'
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS admins (
            admin_id INTEGER PRIMARY KEY,
            assigned_by INTEGER,
            role TEXT DEFAULT 'Assistant'
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS support_links (
            link_id INTEGER PRIMARY KEY AUTOINCREMENT,
            channel_name TEXT,
            url TEXT
        )
    ''')
    
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS dynamic_settings (
            key TEXT PRIMARY KEY,
            value TEXT
        )
    ''')
    
    # Baseline Platform Seeding (In BDT and matching interface design layout)
    platforms = [
        ('Gmail', 25.0, '📧'),
        ('FB_Hotmail', 6.0, '🟦 Hotmail'),
        ('FB_Cookies', 4.0, '🍪 Cookies'),
        ('Instagram', 6.0, '📸'),
        ('Twitter', 8.0, '𝕏'),
        ('TikTok', 7.0, '🎵'),
        ('YouTube', 10.0, '🎬')
    ]
    for plat, price, logo in platforms:
        cursor.execute("INSERT OR IGNORE INTO rates (platform, price, logo) VALUES (?, ?, ?)", (plat, price, logo))
        
    # Global Dynamic Variables Configuration
    settings = [
        ('min_recharge', '40.0'),
        ('min_bkash_nagad', '60.0'),
        ('min_binance_usd', '1.00'),
        ('usd_rate', '120.0'),
        ('ref_commission', '0.50'),
        ('tutorial_video', 'https://youtube.com'),
        ('owner_id', str(OWNER_ID))
    ]
    for key, val in settings:
        cursor.execute("INSERT OR IGNORE INTO dynamic_settings (key, value) VALUES (?, ?)", (key, val))
        
    # Owner Hard-Lock Injection Into Admin Layer
    cursor.execute("INSERT OR IGNORE INTO admins (admin_id, assigned_by, role) VALUES (?, ?, 'Owner')", (OWNER_ID, OWNER_ID, 'Owner'))
    
    # Baseline Multi-Support Links Setup
    cursor.execute("SELECT COUNT(*) FROM support_links")
    if cursor.fetchone()[0] == 0:
        cursor.execute("INSERT INTO support_links (channel_name, url) VALUES (?, ?)", ('Main Support', 'https://t.me/your_support'))
        
    conn.commit()
    conn.close()

# Helper to fetch settings safely
def get_setting(key):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT value FROM dynamic_settings WHERE key=?", (key,))
    row = cursor.fetchone()
    conn.close()
    return row[0] if row else "0"

# Helper to check sequential spam rejections
def is_spammer(user_id):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT status FROM submissions WHERE user_id=? ORDER BY sub_id DESC LIMIT 5", (user_id,))
    rows = cursor.fetchall()
    conn.close()
    if len(rows) == 5 and all(r[0] == 'Rejected' for r in rows):
        return True
    return False

