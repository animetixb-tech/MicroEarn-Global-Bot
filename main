@bot.message_with_type_handler(commands=['addadmin'], content_types=['text'])
def add_admin_privilege(message):
    if message.from_user.id != OWNER_ID: return
    try:
        target_id = int(message.text.split()[1])
        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute("INSERT OR IGNORE INTO admins (admin_id, assigned_by, role) VALUES (?, ?, 'Assistant')", (target_id, OWNER_ID))
        conn.commit()
        conn.close()
        bot.reply_to(message, f"✅ Assistant ID {target_id} successfully added to shift moderation lists.")
    except: bot.reply_to(message, "Syntax: `/addadmin [ID]`")

@bot.message_with_type_handler(commands=['deladmin'], content_types=['text'])
def revoke_admin_privilege(message):
    if message.from_user.id != OWNER_ID: return
    try:
        target_id = int(message.text.split()[1])
        conn = sqlite3.connect(DB_FILE)
        cursor = conn.cursor()
        cursor.execute("DELETE FROM admins WHERE admin_id=? AND role != 'Owner'", (target_id,))
        conn.commit()
        conn.close()
        bot.reply_to(message, f"❌ Moderation access rights fully revoked from Assistant ID {target_id}.")
    except: bot.reply_to(message, "Syntax: `/deladmin [ID]`")

